{
  "manifest_version": 3,
  "name": "Codeship Auto-Pusher",
  "version": "1.0.0",
  "description": "Automatically pushes accepted LeetCode solutions to your GitHub repository.",
  "permissions": [
    "storage",
    "webRequest",
    "cookies",
    "alarms",
    "offscreen"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "http://localhost:3000/*",
    "https://codeship-bay.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://leetcode.com/*"]
    }
  ]
}
